FLASK_APP=rotk.py

FLASK_DEBUG=1

# Secret key for Flask session / WTForms CSRF / itsdangerous tokens.
# Set to a long random string (e.g. `python -c "import secrets; print(secrets.token_hex(32))"`).
SECRET_KEY=''

# --- Postgres ---
# Local dev (with the bundled `db` service in docker-compose.yml): the
# local postgres container is initialised with these values on first boot.
# Shared-postgres production: the role/DB are carved out manually on the
# shared cluster; the override sets POSTGRES_HOST=postgres pointing at it.
POSTGRES_USER='rotk_app'
POSTGRES_PASSWORD=''
POSTGRES_DB='rotk_net'
POSTGRES_HOST='db'
POSTGRES_PORT='5432'

# --- Email (SMTP) ---
# Any SMTP provider works — Mailgun, SendGrid, AWS SES, Postmark, Gmail, etc.
# If MAIL_SERVER is left blank the app suppresses outbound mail and logs the
# message body to stderr instead, which is useful for local dev.
#
# Examples:
#   Mailgun:   MAIL_SERVER=smtp.mailgun.org   MAIL_PORT=587  MAIL_USE_TLS=true
#   SendGrid:  MAIL_SERVER=smtp.sendgrid.net  MAIL_PORT=587  MAIL_USE_TLS=true  MAIL_USERNAME=apikey
#   SES:       MAIL_SERVER=email-smtp.<region>.amazonaws.com  MAIL_PORT=587  MAIL_USE_TLS=true
#   Gmail:     MAIL_SERVER=smtp.gmail.com     MAIL_PORT=587  MAIL_USE_TLS=true  (use an App Password)
MAIL_SERVER=''
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=''
MAIL_PASSWORD=''
MAIL_DEFAULT_SENDER='rotk.net <no-reply@rotk.net>'

# Base URL used inside email templates for links back to the site
# (e.g. https://rotk.net). Leave blank in dev to fall back to request.host_url.
APP_BASE_URL=''

CERTFILE=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
KEYFILE=/etc/letsencrypt/live/yourdomain.com/privkey.pem
